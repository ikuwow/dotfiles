# Safe read-only and utility commands
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["pwd"], decision="allow")
prefix_rule(pattern=["echo"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["tr"], decision="allow")
prefix_rule(pattern=["mkdir"], decision="allow")
prefix_rule(pattern=["tree"], decision="allow")
prefix_rule(pattern=["date"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["uname"], decision="allow")
prefix_rule(pattern=["file"], decision="allow")
prefix_rule(pattern=["realpath"], decision="allow")
prefix_rule(pattern=["readlink"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")
prefix_rule(pattern=["yq"], decision="allow")
prefix_rule(pattern=["ping"], decision="allow")
prefix_rule(pattern=["dig"], decision="allow")
prefix_rule(pattern=["mdfind"], decision="allow")

# Linting and validation
prefix_rule(pattern=["pre-commit"], decision="allow")
prefix_rule(pattern=["shellcheck"], decision="allow")
prefix_rule(pattern=["actionlint"], decision="allow")
prefix_rule(pattern=["yamllint"], decision="allow")
prefix_rule(pattern=["npx", "textlint"], decision="allow")

# Git - forbidden (destructive)
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden", justification="Use normal push")
prefix_rule(pattern=["git", "push", "-f"], decision="forbidden", justification="Use normal push")
prefix_rule(pattern=["git", "reset", "--hard"], decision="forbidden", justification="Destructive operation")
prefix_rule(pattern=["git", "clean", "-f"], decision="forbidden", justification="Destructive operation")
prefix_rule(pattern=["git", "clean", "-fd"], decision="forbidden", justification="Destructive operation")
prefix_rule(pattern=["git", "checkout", "."], decision="forbidden", justification="Discards all changes")
prefix_rule(pattern=["git", "restore", "."], decision="forbidden", justification="Discards all changes")
prefix_rule(pattern=["git", "add", "."], decision="forbidden", justification="Use specific file paths")
prefix_rule(pattern=["git", "add", "-A"], decision="forbidden", justification="Use specific file paths")

# Git - allow (read-only and safe)
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "remote"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "pull"], decision="allow")
prefix_rule(pattern=["git", "stash", "list"], decision="allow")
prefix_rule(pattern=["git", "stash", "show"], decision="allow")
prefix_rule(pattern=["git", "tag"], decision="allow")
prefix_rule(pattern=["git", "rev-parse"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")
prefix_rule(pattern=["git", "ls-remote"], decision="allow")
prefix_rule(pattern=["git", "blame"], decision="allow")
prefix_rule(pattern=["git", "shortlog"], decision="allow")
prefix_rule(pattern=["git", "describe"], decision="allow")
prefix_rule(pattern=["git", "grep"], decision="allow")
prefix_rule(pattern=["git", "worktree", "list"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "switch"], decision="allow")
prefix_rule(pattern=["git", "restore"], decision="allow")
prefix_rule(pattern=["git-worktree-create"], decision="allow")

# GitHub CLI - allow (read-only)
prefix_rule(pattern=["gh", "pr", ["list", "view", "diff", "checks"]], decision="allow")
prefix_rule(pattern=["gh", "issue", ["list", "view"]], decision="allow")
prefix_rule(pattern=["gh", "run", ["list", "view", "watch"]], decision="allow")
prefix_rule(pattern=["gh", "search"], decision="allow")
prefix_rule(pattern=["gh", "repo", ["list", "view"]], decision="allow")

# GitHub CLI - allow (write, needed for workflow)
prefix_rule(pattern=["gh", "pr", ["create", "edit", "ready"]], decision="allow")
prefix_rule(pattern=["gh", "issue", "create"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")

# Brew
prefix_rule(pattern=["brew", "info"], decision="allow")
prefix_rule(pattern=["brew", "services", "list"], decision="allow")

# Docker
prefix_rule(pattern=["docker", "compose", "ps"], decision="allow")

# Terraform (read-only)
prefix_rule(pattern=["terraform", ["validate", "fmt", "plan"]], decision="allow")

# Cloud tools (read-only)
prefix_rule(pattern=["gcloud", "auth", "list"], decision="allow")
prefix_rule(pattern=["gcloud", "services", "list"], decision="allow")
prefix_rule(pattern=["colima", "status"], decision="allow")

# mise (read-only)
prefix_rule(pattern=["mise", ["list", "ls", "current", "where", "which", "doctor", "env", "version"]], decision="allow")
prefix_rule(pattern=["mise", "--version"], decision="allow")
prefix_rule(pattern=["mise", "settings", ["list", "get"]], decision="allow")
prefix_rule(pattern=["mise", "plugins", ["list", "ls"]], decision="allow")

# Monitoring tools
prefix_rule(pattern=["dog", "--help"], decision="allow")
prefix_rule(pattern=["dog", "dashboard", ["--help", "show"]], decision="allow")
prefix_rule(pattern=["dog", "search", ["query", "--help"]], decision="allow")
prefix_rule(pattern=["dog", "monitor", ["--help", "search", "query", "show", "show_all"]], decision="allow")

# Custom scripts
prefix_rule(pattern=["aps", ["--list", "--help"]], decision="allow")
prefix_rule(pattern=["gps", ["--list", "--help"]], decision="allow")
prefix_rule(pattern=["pup", "--read-only"], decision="allow")
